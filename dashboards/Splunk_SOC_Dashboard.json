  "dataSources": {
    "ds_QiO5DWw5": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=WinEventLog:Security\r\n| stats count"
      },
      "name": "Search_1"
    },
    "ds_Tl9DrH0M": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=WinEventLog:Security EventCode=4625\r\n| stats count"
      },
      "name": "Search_2"
    },
    "ds_5FLY25GE": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=WinEventLog:Security EventCode=4624\r\n| stats count"
      },
      "name": "Search_3"
    },
    "ds_wKmcDVC4": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=WinEventLog:Security\r\n| timechart count"
      },
      "name": "Search_4"
    },
    "ds_mm2NryMV": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=WinEventLog:Security\r\n| table _time EventCode Account_Name ComputerName Message\r\n| head 20"
      },
      "name": "Search_5"
    },
    "ds_wrSWHnOc": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=WinEventLog:Security\r\n| top limit=10 EventCode"
      },
      "name": "Search_6"
    },
    "ds_RJy2Q422": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=WinEventLog:Security\r\n| top limit=10 Account_Name"
      },
      "name": "Search_7"
    },
    "ds_oX9LOOZ8": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=WinEventLog:Security\r\n| top limit=10 host"
      },
      "name": "Search_8"
    },
    "ds_W6fSCADT": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=WinEventLog:Security\r\n| stats count by EventCode"
      },
      "name": "Search_9"
    },
    "ds_nsuBA2eg": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=WinEventLog:Security EventCode=4625\r\n| timechart count"
      },
      "name": "Search_10"
    },
    "ds_FybdTQzq": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=\"XmlWinEventLog:Microsoft-Windows-Sysmon/Operational\"\r\n| stats count"
      },
      "name": "Search_11"
    },
    "ds_WSh7M4nk": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=\"XmlWinEventLog:Microsoft-Windows-Sysmon/Operational\"\r\n| rex field=_raw \"<EventID>(?<EventID>\\d+)</EventID>\"\r\n| search EventID=1\r\n| timechart count"
      },
      "name": "Search_12"
    },
    "ds_aQyNIf3r": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=\"XmlWinEventLog:Microsoft-Windows-Sysmon/Operational\"\r\n| rex field=_raw \"<Data Name='Image'>(?<Image>.*?)</Data>\"\r\n| top limit=10 Image"
      },
      "name": "Search_13"
    },
    "ds_xnmxySwJ": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=\"XmlWinEventLog:Microsoft-Windows-Sysmon/Operational\"\r\n| rex field=_raw \"<EventID>(?<EventID>\\d+)</EventID>\"\r\n| stats count by EventID"
      },
      "name": "Search_14"
    },
    "ds_XnDdhPpD": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=\"XmlWinEventLog:Microsoft-Windows-Sysmon/Operational\"\r\n| rex field=_raw \"<EventID>(?<EventID>\\d+)</EventID>\"\r\n| search EventID=3\r\n| table _time host _raw"
      },
      "name": "Search_15"
    },
    "ds_cMR2FsEp": {
      "type": "ds.search",
      "options": {
        "query": "index=* sourcetype=\"XmlWinEventLog:Microsoft-Windows-Sysmon/Operational\"\r\n| rex field=_raw \"<EventID>(?<EventID>\\d+)</EventID>\"\r\n| search EventID=22\r\n| table _time host _raw"
      },
      "name": "Search_16"
    }
  },
  "defaults": {
    "dataSources": {
      "ds.search": {
        "options": {
          "queryParameters": {
            "latest": "$global_time.latest$",
            "earliest": "$global_time.earliest$"
          }
        }
      },
      "ds.spl2": {
        "options": {
          "queryParameters": {
            "latest": "$global_time.latest$",
            "earliest": "$global_time.earliest$"
          }
        }
      }
    },
    "visualizations": {
      "global": {
        "showProgressBar": true
      }
    }
  },
